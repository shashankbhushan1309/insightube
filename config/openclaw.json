{
    "gateway": {
        "mode": "standalone"
    },
    "providers": {
        "google": {
            "api": "openai",
            "baseUrl": "https://generativelanguage.googleapis.com/v1beta/openai/",
            "apiKey": "${GEMINI_API_KEY}",
            "models": [
                "gemini-2.0-flash"
            ]
        }
    },
    "agents": {
        "defaults": {
            "model": {
                "primary": "gemini-2.0-flash"
            }
        }
    },
    "channel": {
        "telegram": {
            "enabled": true,
            "botToken": "${TELEGRAM_BOT_TOKEN}",
            "dmPolicy": "open",
            "streaming": "partial",
            "customCommands": [
                {
                    "command": "summary",
                    "description": "Regenerate the video summary"
                },
                {
                    "command": "deepdive",
                    "description": "Deep analysis of the video"
                },
                {
                    "command": "actionpoints",
                    "description": "Extract actionable takeaways"
                },
                {
                    "command": "language",
                    "description": "Set language: hindi / english"
                },
                {
                    "command": "clear",
                    "description": "Clear session and start fresh"
                }
            ]
        }
    },
    "skills": {
        "load": {
            "workspace": true
        },
        "entries": {
            "youtube-summarizer": {
                "enabled": true
            }
        }
    },
    "tools": {
        "allow": [
            "exec",
            "read",
            "write"
        ]
    },
    "sessions": {
        "store": "file",
        "ttlSeconds": 3600
    }
}